# SRE Event Watchdog — configuration (all optional; sane defaults applied)

# --- Storage ---
WATCHDOG_DB_PATH=data/watchdog.db

# --- Detection ---
WATCHDOG_BUCKET_SECONDS=10
WATCHDOG_Z_THRESHOLD=6.0
WATCHDOG_IFOREST_WARMUP=30
WATCHDOG_ALERT_THRESHOLD=0.7

# --- Alerting ---
WATCHDOG_WEBHOOK_URL=http://localhost:8001/webhook
WATCHDOG_ALERT_COOLDOWN_SECONDS=30

# --- Synthetic generator ---
WATCHDOG_GENERATOR=true

# --- LLM layer (GenAI showcase; app runs fully without these) ---
WATCHDOG_LLM_ENABLED=false
WATCHDOG_LLM_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...
